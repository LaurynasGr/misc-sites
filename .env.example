# Password gate for the deployed report, enforced by the Vercel Edge middleware
# (middleware.ts). Set it (in the Vercel project's env vars) to require a password
# before the report is shown; leave it unset to serve openly. The local dev server
# (bun run dev/start) is always ungated — set this in Vercel, not just here.
APP_PASSWORD="change-me"
# Optional: HMAC key that signs the session cookie. Defaults to APP_PASSWORD if unset.
# Generate one with: openssl rand -base64 32
# SESSION_SECRET="a-long-random-string"
